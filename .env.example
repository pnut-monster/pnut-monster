# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (required for CSRF origin checks in production)
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Google OAuth (Google Cloud OAuth 2.0 Web application credentials)
# Authorized redirect URI in Google Cloud:
# https://<your-project-ref>.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS S3
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# CDN (optional — if using CloudFront or custom domain)
NEXT_PUBLIC_CDN_URL=https://cdn.your-domain.com

# AWS SES + private S3 email templates
# Prefer an IAM role/workload identity in production instead of static keys.
AWS_SES_REGION=ap-south-1
SES_FROM_EMAIL=noreply@pnut.monster
SES_FROM_NAME=PNUT Monster
SES_REPLY_TO_EMAIL=support@pnut.monster
SES_CONFIGURATION_SET=
AWS_EMAIL_TEMPLATE_BUCKET=your-private-template-bucket
AWS_EMAIL_TEMPLATE_REGION=ap-south-1
AWS_EMAIL_TEMPLATE_PREFIX=email-templates
EMAIL_TEMPLATE_CACHE_TTL_SECONDS=300
EMAIL_TEMPLATE_CACHE_MAX_ENTRIES=100
EMAIL_TEMPLATE_ALLOW_STALE_ON_ERROR=true
EMAIL_COMPANY_NAME=PNUT Monster Foods Private Limited
EMAIL_BRAND_NAME=PNUT MONSTER
EMAIL_BRAND_COLOR=#15803d
EMAIL_ACCENT_COLOR=#facc15
EMAIL_SUPPORT_EMAIL=support@pnut.monster
EMAIL_LOGO_URL=https://pnut.monster/icons/icon-192x192.png
EMAIL_PRIVACY_URL=https://pnut.monster/privacy
EMAIL_TERMS_URL=https://pnut.monster/terms
EMAIL_CONTACT_URL=https://pnut.monster/contact
EMAIL_INSTAGRAM_URL=https://instagram.com/pnutmonster
EMAIL_FACEBOOK_URL=https://facebook.com/pnutmonster
EMAIL_X_URL=https://x.com/pnutmonster
EMAIL_FOOTER_TEXT=Healthy food, made monstrously delicious.

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
