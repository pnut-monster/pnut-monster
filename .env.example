# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (required for CSRF origin checks in production)
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Google OAuth (Google Cloud OAuth 2.0 Web application credentials)
# Authorized redirect URI in Google Cloud:
# https://<your-project-ref>.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AWS S3
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# CDN (optional — if using CloudFront or custom domain)
NEXT_PUBLIC_CDN_URL=https://cdn.your-domain.com

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
