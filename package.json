{
  "name": "pnut-monster",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "predev": "node scripts/clean-dev-artifacts.mjs",
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "build:cloudflare": "opennextjs-cloudflare build",
    "preview:cloudflare": "npm run build:cloudflare && wrangler dev",
    "deploy:cloudflare": "npm run build:cloudflare && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint",
    "test:audit": "node scripts/audit-regression.mjs",
    "test:db-audit": "node scripts/db/audit-regression.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "email:templates:validate": "node scripts/email/validate-templates.mjs",
    "email:templates:test-delivery": "tsx scripts/email/test-all-templates.ts",
    "email:templates:upload": "npm run email:templates:validate && node scripts/email/upload-templates.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-iam": "^3.1090.0",
    "@aws-sdk/client-route-53": "^3.1090.0",
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/client-ses": "^3.1083.0",
    "@aws-sdk/client-sts": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@serwist/next": "^9.5.6",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.110.8",
    "buffer": "^6.0.3",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "next": "15",
    "razorpay": "^2.9.6",
    "react": "18",
    "react-dom": "18",
    "react-hot-toast": "^2.6.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.1.1",
    "pg": "^8.22.0",
    "serwist": "^9.5.6",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "postcss": "^8.5.16"
  }
}
